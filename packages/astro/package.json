{
  "name": "astro-headless-comments",
  "version": "1.0.0",
  "description": "A headless comments solution for Astro by using LibSQL",
  "keywords": [
    "headless",
    "astro-adapter",
    "astro-component",
    "withastro",
    "media"
  ],
  "bugs": {
    "url": "https://github.com/syhily/astro-headless-comments/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/syhily/astor-headless-comments"
  },
  "license": "MIT",
  "author": "Yufan Sheng <syhily@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./env.d.ts": "./env.d.ts",
    "./assets/*": "./assets/*",
    "./pages/*": "./pages/*"
  },
  "main": "./index.ts",
  "files": [
    "./assets/**/*",
    "./components/**/*",
    "./layouts/**/*",
    "./libs/**/*",
    "./pages/**/*",
    "./*.d.ts",
    "./*.ts",
    "./package.json"
  ],
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "autoprefixer": "^10.4.20",
    "better-auth": "^1.1.11",
    "drizzle-orm": "^0.38.3",
    "nodemailer": "^6.9.16",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "astro": "^5.1.6"
  },
  "peerDependencies": {
    "astro": "^5.0.0"
  }
}
