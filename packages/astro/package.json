{
  "name": "astro-headless-comments",
  "version": "1.0.0",
  "description": "A headless comments solution for Astro by using LibSQL",
  "keywords": [
    "headless",
    "astro-adapter",
    "astro-component",
    "withastro",
    "media"
  ],
  "bugs": {
    "url": "https://github.com/syhily/astro-headless-comments/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/syhily/astor-headless-comments"
  },
  "license": "MIT",
  "author": "Yufan Sheng <syhily@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./env.d.ts": "./env.d.ts",
    "./assets/*": "./assets/*",
    "./pages/*": "./pages/*"
  },
  "files": [
    "./assets/**/*",
    "./components/**/*",
    "./layouts/**/*",
    "./libs/**/*",
    "./pages/**/*",
    "./*.d.ts",
    "./*.ts",
    "./package.json"
  ],
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@popperjs/core": "^2.11.8",
    "better-auth": "^1.1.11",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "drizzle-orm": "^0.38.3",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@types/bootstrap": "^5.2.10",
    "@types/node": "^22.10.5",
    "astro": "^5.1.5"
  },
  "peerDependencies": {
    "astro": "^5.0.0"
  }
}
